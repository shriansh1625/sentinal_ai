{
  "name": "sentinel-shield",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Sentinel Shield AI — local-first privacy assistant for AI platforms (Sprint 0 foundation)",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "turbo run test --filter=./packages/*",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,mjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,cjs,mjs,json,md,yml,yaml}\"",
    "depcruise": "depcruise packages --config tools/dep-cruiser/.dependency-cruiser.cjs",
    "purity": "node tools/engine-purity/check.mjs",
    "doc-lint": "node tools/doc-lint/check.mjs",
    "bench:budgets": "node tools/benchmarks/check-budgets.mjs",
    "eval:detection": "pnpm --filter @sentinel-shield/detection-engine build && node tools/eval-harness/run-eval.mjs",
    "ci": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm purity && pnpm depcruise && pnpm doc-lint && pnpm bench:budgets && pnpm --filter @sentinel-shield/extension verify:bundle && node tools/certification/check.mjs",
    "certify": "node tools/certification/check.mjs",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^3.2.4",
    "dependency-cruiser": "^16.8.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "packages/*/src/**/*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{ts,tsx,js,cjs,mjs}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
