{
  "name": "@sentinel-shield/browser-adapters",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@sentinel-shield/core": "workspace:*",
    "@sentinel-shield/shared-types": "workspace:*",
    "hash-wasm": "^4.12.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
